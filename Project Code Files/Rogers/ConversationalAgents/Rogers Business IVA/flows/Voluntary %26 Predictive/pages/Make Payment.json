  "displayName": "Make Payment",
  "form": {
  
  },
  "entryFulfillment": {
    "conditionalCases": [ {
      "cases": [ {
        "condition": "$session.params.StdErrorCount = 0",
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "\u003cspeak\u003eI see your account is cancelled, but there's an outstanding balance. Would you like to make a payment now?\u003c/speak\u003e" ]
            },
            "languageCode": "en"
          }
        }, {
          "message": {
            "text": {
              "text": [ "Je vois que votre compte est annulé, mais qu’un solde impayé demeure. Voulez-vous effectuer un paiement maintenant ?" ]
            },
            "languageCode": "fr-ca"
          }
        } ]
      }, {
        "condition": "$session.params.StdErrorCount = 1 AND $session.params.LastStdError = \"NM\"",
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "\u003cspeak\u003eI'm sorry, I didn't get that. Would you like to make a payment now? You can say yes or no.\u003c/speak\u003e" ]
            },
            "languageCode": "en"
          }
        }, {
          "message": {
            "text": {
              "text": [ "Je suis désolé, je n’ai pas compris. Voulez-vous effectuer un paiement maintenant ? Vous pouvez dire « oui » ou « non »." ]
            },
            "languageCode": "fr-ca"
          }
        } ]
      }, {
        "condition": "$session.params.StdErrorCount = 1 AND $session.params.LastStdError = \"NI\"",
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "\u003cspeak\u003eI'm sorry, I didn't hear that. Would you like to make a payment now? You can say yes or no.\u003c/speak\u003e" ]
            },
            "languageCode": "en"
          }
        }, {
          "message": {
            "text": {
              "text": [ "Je suis désolé, je ne vous ai pas entendu. Voulez-vous effectuer un paiement maintenant ? Vous pouvez dire « oui » ou « non »." ]
            },
            "languageCode": "fr-ca"
          }
        } ]
      }, {
        "condition": "$session.params.StdErrorCount = 2 AND $session.params.LastStdError = \"NI\"",
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "\u003cspeak\u003eIf you would like to make a payment say yes or press 1. Otherwise say no or press 2.\u003c/speak\u003e" ]
            },
            "languageCode": "en"
          }
        }, {
          "message": {
            "text": {
              "text": [ "Si vous voulez effectuer un paiement, dites « oui » ou appuyez sur 1. Sinon, dites « non » ou appuyez sur 2." ]
            },
            "languageCode": "fr-ca"
          }
        } ]
      }, {
        "condition": "$session.params.StdErrorCount = 2 AND $session.params.LastStdError = \"NM\"",
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "\u003cspeak\u003eIf you would like to make a payment say yes or press 1. Otherwise say no or press 2.\u003c/speak\u003e" ]
            },
            "languageCode": "en"
          }
        }, {
          "message": {
            "text": {
              "text": [ "Si vous voulez effectuer un paiement, dites « oui » ou appuyez sur 1. Sinon, dites « non » ou appuyez sur 2." ]
            },
            "languageCode": "fr-ca"
          }
        } ]
      }, {
      
      } ]
