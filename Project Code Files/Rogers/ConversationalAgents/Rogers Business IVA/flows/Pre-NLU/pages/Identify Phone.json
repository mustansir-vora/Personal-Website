{
  "name": "e3593300-7b5a-4099-9bd9-6dfb822c1b47",
  "displayName": "Identify Phone",
  "form": {
  
  },
  "entryFulfillment": {
  
  },
  "transitionRoutes": [ {
    "condition": "$session.params.returnCode = \"0\" AND $session.params.numberOfBillingAccounts \u003e= 1",
    "triggerFulfillment": {
      "setParameterActions": [ {
        "parameter": "getCallerProfileAPISuccess",
        "value": true
      } ]
    },
    "targetPage": "Billing Account Check",
    "name": "1db4cec5-5024-4615-a36e-5c8f72ebbb07"
  }, {
    "condition": "$session.params.returnCode = \"1\" OR $session.params.numberOfBillingAccounts = 0 OR $session.params.numberOfBillingAccounts = \"NA\"",
    "triggerFulfillment": {
      "setParameterActions": [ {
        "parameter": "phoneRetryCounter",
        "value": "$sys.func.ADD($session.params.phoneRetryCounter,1)"
      }, {
        "parameter": "getCallerProfileAPISuccess",
        "value": false
      } ]
    },
    "targetPage": "Check Max Phone Retry",
    "name": "d9c5d68c-b110-4fc7-9130-08795773fdba"
  } ]
