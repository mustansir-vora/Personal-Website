            },
            "languageCode": "fr-ca"
          }
        } ]
      }, {
        "condition": "$session.params.StdErrorCount = 2 AND $session.params.LastStdError = \"NM\"",
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "I'm sorry, I still didn't get that,  $session.params.voiceScriptContent ,Please say \"yes\" or Press 1, otherwise say \"no\" or press 2" ]
            },
            "languageCode": "en"
          }
        }, {
          "message": {
