  "entryFulfillment": {
    "conditionalCases": [ {
      "cases": [ {
        "condition": "$session.params.AgentRequest1stAttempt = true",
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "Let’s try that again. Please describe briefly what you need help with. How can I help you today?" ]
            },
            "languageCode": "en"
          }
        }, {
          "message": {
            "text": {
              "text": [ "Réessayons. Veuillez décrire brièvement le service ou produit pour lequel vous avez besoin d’aide." ]
            },
            "languageCode": "fr-ca"
          }
        } ]
      }, {
        "condition": "$session.params.AgentRequest2ndAttempt = true",
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "I understand you’re looking for a Business Specialist, but I may be able to help you quicker if you share the reason for your call. How can I help you today?" ]
            },
            "languageCode": "en"
          }
        }, {
          "message": {
            "text": {
              "text": [ "Je comprends que vous souhaitez parler à nos spécialistes Affaires, mais je pourrais vous aider plus rapidement si vous me disiez la raison de votre appel." ]
            },
            "languageCode": "fr-ca"
          }
        } ]
      }, {
        "condition": "$session.params.nluConfig.destinationType = \"Reprompt\"",
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "$session.params.nluConfig.repromptMenu_EN" ]
            },
            "languageCode": "en"
          }
        }, {
          "message": {
            "text": {
              "text": [ "$session.params.nluConfig.repromptMenu_FR" ]
            },
            "languageCode": "fr-ca"
          }
        } ]
      }, {
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "How can I help you today?" ]
            },
            "languageCode": "en"
          }
        }, {
          "message": {
            "text": {
              "text": [ "Comment puis-je vous aider aujourd'hui?" ]
            },
            "languageCode": "fr-ca"
          }
        } ]
      } ]
    } ]
  },
