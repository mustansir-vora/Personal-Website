  "entryFulfillment": {
    "messages": [ {
      "text": {
        "text": [ "Pour l’Internet par câble d’entreprise, dites « internet entreprise ».\r\nPour l’Internet de fournisseurs tiers, dites « fournisseurs tiers ».\r\nTéléphone d’affaires Rogers, dites « téléphone d’affaires ».\r\nCentre de données, dites « centre de données ».\r\nServices gérés, dites « services gérés ».\r\nPour la Fibre et tous les autres services, dites « autre »." ]
      },
      "languageCode": "fr-ca"
    }, {
      "text": {
        "text": [ "For enterprise cable Internet, say \"enterprise internet\",\nFor third party internet, say \"third party\",\nFor Rogers Business Phone, say \"business phone\",\nFor Data Centre, say \"data centre\",\nFor Managed Services, say \"managed services\",\nFor Fiber and all other services, say \"other\"." ]
      },
      "languageCode": "en"
    } ]
  },
