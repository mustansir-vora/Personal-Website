            "primitiveTransformation": { "replaceWithInfoTypeConfig": {} }
          },
          {
            "infoTypes": [{ "name": "LOCATION" }, { "name": "STREET_ADDRESS" }, { "name": "ROGERS_CONTEXTUAL_ADDRESS" }],
            "primitiveTransformation": { "replaceWithInfoTypeConfig": {} }
