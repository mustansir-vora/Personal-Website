        "languageCode": "fr-ca"
      }, {
        "text": {
          "text": [ "The payment amount must be between $session.params.minAmountToCompare and $session.params.maxAmountToCompare . " ]
        },
        "languageCode": "en"
      } ]
    },
    "targetPage": "Check Get Amount Counter",
