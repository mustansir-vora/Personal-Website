{
  "name": "70191250-7570-4b3b-9a1a-f301bdcde9c3",
  "displayName": "PTP Validate Amount",
  "form": {
  
  },
  "entryFulfillment": {
    "setParameterActions": [ {
      "parameter": "ptpChangeAmount",
      "value": true
    }, {
      "parameter": "collectedPtpAmount",
      "value": "$session.params.changePTPAmount.amount"
    }, {
      "parameter": "$session.params.fromValidatePTPAmount",
      "value": false
    } ]
  },
  "transitionRoutes": [ {
    "condition": "$sys.func.TO_NUMBER($session.params.collectedPtpAmount) \u003e $session.params.maxAmountToCompare OR $sys.func.TO_NUMBER($session.params.collectedPtpAmount) \u003c $session.params.minAmountToCompare",
