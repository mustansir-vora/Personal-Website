      "text": {
        "text": [ "Would you like to pay the amount to prevent collection activities of $session.params.pastDueBalance ?" ]
      },
      "languageCode": "en"
    }, {
      "text": {
        "text": [ "Souhaitez-vous payer le montant de $session.params.pastDueBalance afin d’éviter les activités de recouvrement ?" ]
      },
      "languageCode": "fr-ca"
    } ]
  },
