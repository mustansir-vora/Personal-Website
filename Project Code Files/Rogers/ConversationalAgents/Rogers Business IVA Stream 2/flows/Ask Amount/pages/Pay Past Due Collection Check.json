    "condition": "$session.params.userPayPastDueCollectionConfirmation = yes",
    "triggerFulfillment": {
      "setParameterActions": [ {
        "parameter": "paymentDue",
        "value": "$sys.func.TO_NUMBER($session.params.pastDueBalance)"
      } ]
