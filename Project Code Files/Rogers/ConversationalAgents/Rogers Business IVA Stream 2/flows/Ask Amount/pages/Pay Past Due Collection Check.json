  "form": {
    "parameters": [ {
      "displayName": "userPayPastDueCollectionConfirmation",
      "required": true,
      "entityType": "@e_YesNo",
      "fillBehavior": {
        "initialPromptFulfillment": {
        
        },
        "repromptEventHandlers": [ {
          "targetPage": "End Flow",
