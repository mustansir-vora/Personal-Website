{
  "name": "ab65104e-a972-476f-b87d-b12324d1e49b",
  "displayName": "Collect Yes or No Outage Notification",
  "form": {
  
  },
  "entryFulfillment": {
    "conditionalCases": [ {
      "cases": [ {
        "condition": "$session.params.retryCount = 0",
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "Souhaitez-vous être avisé lorsque l’interruption de service sera résolue ?" ]
            },
            "languageCode": "fr-ca"
          }
        }, {
          "message": {
            "text": {
              "text": [ "Would you like to be notified once the service interruption has been resolved?" ]
            },
            "languageCode": "en"
          }
        } ]
      }, {
        "condition": "$session.params.retryCount = 1 AND $session.params.stdError = \"NI\"",
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "Je suis désolé, je ne vous ai pas entendu. Si vous souhaitez être avisé lorsque l’interruption de service sera résolue, dites « oui » ou appuyez sur le 1. Sinon, dites « non » ou appuyez sur le 2." ]
            },
            "languageCode": "fr-ca"
          }
        }, {
          "message": {
            "text": {
              "text": [ "I'm sorry, I couldn't hear that. If you'd like to be notified when the service interruption has been resolved, say yes or press one. Otherwise, say no or press two." ]
            },
            "languageCode": "en"
          }
        } ]
      }, {
        "condition": "$session.params.retryCount = 1 AND $session.params.stdError = \"NM\"",
        "caseContent": [ {
          "message": {
            "text": {
              "text": [ "Je suis désolé, je n’ai pas compris. Si vous souhaitez être avisé lorsque l’interruption de service sera résolue, dites « oui » ou appuyez sur le 1. Sinon, dites « non » ou appuyez sur le 2." ]
            },
            "languageCode": "fr-ca"
          }
        }, {
          "message": {
            "text": {
              "text": [ "I'm sorry, I didn't get that. If you'd like to be notified when the service interruption has been resolved, say yes or press one. Otherwise, say no or press two." ]
            },
            "languageCode": "en"
          }
        } ]
      }, {
      
      } ]
    } ]
  },
