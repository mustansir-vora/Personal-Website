    "name": "236c32eb-6fad-4e8a-bd66-acae5aecc340"
  }, {
    "condition": "$session.params.api.billingProfile.balanceDetails.currentBalance \u003e 0",
    "triggerFulfillment": {
    
    },
    "targetPage": "Play CurrentBalance",
    "name": "c05bfbe2-2499-4847-a2e4-d7ec7cdfc23e"
  }, {
    "condition": "$session.params.api.billingProfile.balanceDetails.currentBalance \u003c 0",
    "triggerFulfillment": {
    
    },
