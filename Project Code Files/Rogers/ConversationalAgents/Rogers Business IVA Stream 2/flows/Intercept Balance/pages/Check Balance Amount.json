{
  "name": "68302650-f59f-49e9-8a3a-d9b763874e5f",
  "displayName": "Check Balance Amount",
  "form": {
  
  },
  "entryFulfillment": {
    "setParameterActions": [ {
      "parameter": "selfServiceCompleted",
      "value": "true"
    }, {
      "parameter": "completedSSName",
      "value": "$sys.func.CONCATENATE($sys.func.CONCATENATE($session.params.completedSSName, \", \"), \"active-interceptBalance\")"
    } ]
  },
  "transitionRoutes": [ {
    "condition": "$session.params.api.billingProfile.balanceDetails.currentBalance = 0",
    "triggerFulfillment": {
    
