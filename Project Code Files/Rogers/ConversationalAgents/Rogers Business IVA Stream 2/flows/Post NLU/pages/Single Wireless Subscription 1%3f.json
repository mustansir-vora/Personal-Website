      }, {
        "parameter": "subscriptionITNMatchCalledFrom",
        "value": "confirmSubscription_A"
      } ]
    },
    "targetPage": "Start Subscription ITN Match",
    "name": "d10ba166-5f52-424f-827a-a9b2fd2b775b"
  }, {
    "condition": "$session.params.numberOfWireless \u003e 1",
    "triggerFulfillment": {
    
    },
    "targetPage": "Check ID Type - Confirm Subscription",
    "name": "5d7958b7-4dc7-4681-a480-7fa90762d1c7"
  } ]
