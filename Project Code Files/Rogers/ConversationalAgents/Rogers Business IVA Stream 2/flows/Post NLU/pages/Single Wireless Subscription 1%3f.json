{
  "name": "ee61f7bd-9a80-4e44-9b1e-387730b8eeaa",
  "displayName": "Single Wireless Subscription 1?",
  "form": {
  
  },
  "entryFulfillment": {
  
  },
  "transitionRoutes": [ {
    "condition": "$session.params.numberOfWireless = 0",
    "triggerFulfillment": {
      "setParameterActions": [ {
        "parameter": "reusablePhoneNumberCalledFrom",
        "value": "confirmSubscription"
      } ]
    },
    "targetPage": "Start Reusable Phone Number",
    "name": "97abae12-108a-4136-ae47-1bc5f3186b7d"
  }, {
    "condition": "$session.params.numberOfWireless = 1",
