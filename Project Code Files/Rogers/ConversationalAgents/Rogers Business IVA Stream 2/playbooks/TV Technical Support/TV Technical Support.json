  "tokenCount": 827,
  "instruction": {
    "steps": [ {
      "text": "Step 1. identify the caller",
      "steps": [ {
        "text": "if $customerIdentified is true goto Step 2"
      }, {
        "text": "otherwise goto Step 2"
      } ]
    }, {
      "text": "Step 2. check line of business",
      "steps": [ {
        "text": "if $IsBusinessApp is true Step 4"
      }, {
        "text": "otherwise goto Step 3"
      } ]
    }, {
      "text": "Step 3. set consumer support routing",
      "steps": [ {
        "text": "Set $selfServiceAttempted as true"
      }, {
        "text": "if $attemptedSSName is empty or equal to null",
        "steps": [ {
          "text": "Set $attemptedSSName as \"passive-techSupportTv\""
        }, {
          "text": "Set $reportingVar_attemptedSSName as $attemptedSSName"
        } ]
      }, {
        "text": "if $attemptedSSName is not empty or equal to null",
        "steps": [ {
          "text": "Set $attemptedSSName as $sys.func.CONCATENATE(\"$session.params.attemptedSSName\",\",passive-techSupportTv\")"
        }, {
          "text": "Set $reportingVar_attemptedSSName as $attemptedSSName"
        } ]
      }, {
        "text": "Set $selfServiceCompleted as true"
      }, {
        "text": "if $completedSSName is empty or equal to null",
        "steps": [ {
          "text": "Set $completedSSName as \"passive-techSupportTv\""
        }, {
          "text": "Set $reportingVar_completedSSName as $completedSSName"
        }, {
          "text": "Set $completedSelfServe as $completedSSName"
        } ]
      }, {
        "text": "if $completedSSName is not empty or equal to null",
        "steps": [ {
          "text": "Set $completedSSName as $sys.func.CONCATENATE(\"$session.params.completedSSName\",\",passive-techSupportTv\")"
        }, {
          "text": "Set $reportingVar_completedSSName as $completedSSName"
        }, {
          "text": "Set $completedSelfServe as $completedSSName"
        } ]
      }, {
        "text": "respond to caller as \"To troubleshoot your issue, you'll need to be at home to have access to your TV equipment.\"."
      }, {
        "text": "pause 1.5 seconds"
      }, {
        "text": "goto Step 5"
      } ]
    }, {
      "text": "Step 4. set business support routing",
      "steps": [ {
        "text": "Set $selfServiceAttempted as true"
      }, {
        "text": "if $attemptedSSName is empty or equal to null",
        "steps": [ {
          "text": "Set $attemptedSSName as \"passive-techSupportTv\""
        }, {
          "text": "Set $reportingVar_attemptedSSName as $attemptedSSName"
        } ]
      }, {
        "text": "if $attemptedSSName is not empty or equal to null",
        "steps": [ {
          "text": "Set $attemptedSSName as $sys.func.CONCATENATE(\"$session.params.attemptedSSName\",\",passive-techSupportTv\")"
        }, {
          "text": "Set $reportingVar_attemptedSSName as $attemptedSSName"
        } ]
      }, {
        "text": "Set $selfServiceCompleted as true"
      }, {
        "text": "if $completedSSName is empty or equal to null",
        "steps": [ {
          "text": "Set $completedSSName as \"passive-techSupportTv\""
        }, {
          "text": "Set $reportingVar_completedSSName as $completedSSName"
        }, {
          "text": "Set $completedSelfServe as $completedSSName"
        } ]
      }, {
        "text": "if $completedSSName is not empty or equal to null",
        "steps": [ {
          "text": "Set $completedSSName as $sys.func.CONCATENATE(\"$session.params.completedSSName\",\",passive-techSupportTv\")"
        }, {
          "text": "Set $reportingVar_completedSSName as $completedSSName"
        }, {
          "text": "Set $completedSelfServe as $completedSSName"
        } ]
      }, {
        "text": "respond to caller as \"To troubleshoot your issue, you'll need to have access to your TV equipment\"."
      }, {
        "text": "goto Step 5"
      } ]
    }, {
      "text": "Step 5. validate tv product",
      "steps": [ {
        "text": "if numberOfTV is greater than 0",
        "steps": [ {
          "text": "set $hasTvProfile as true"
        }, {
          "text": "set $subscriptionAccountDetails as `get_account_details`,return the call"
        } ]
      }, {
        "text": "otherwise",
        "steps": [ {
          "text": "set $hasTvProfile as false,return the call"
        } ]
      } ]
    } ]
  },
  "playbookType": "ROUTINE",
  "codeBlock": {
    "code": "@Action\r\ndef get_account_details() -\u003e dict:\r\n    \"\"\"Get linkedAccountNumber and linkedAccountSystem for Internet service\"\"\"\r\n\r\n    subscriptions = state[\"$session.params.subscriptionsList\"]\r\n\r\n    result = {\r\n        \"linkedAccountNumber\": None,\r\n        \"linkedAccountSystem\": None\r\n    }\r\n\r\n    if not subscriptions:\r\n        return result\r\n\r\n    for item in subscriptions:\r\n        service_category = item.get(\"serviceCategory\", {}).get(\"english\", \"\").strip().lower()\r\n\r\n        if service_category == \"tv\":\r\n            result[\"linkedAccountNumber\"] = item.get(\"linkedAccountNumber\")\r\n            result[\"linkedAccountSystem\"] = item.get(\"linkedAccountSystem\")\r\n            return result\r\n\r\n    return result"
  },
  "inlineActions": [ "get_account_details" ]
}
