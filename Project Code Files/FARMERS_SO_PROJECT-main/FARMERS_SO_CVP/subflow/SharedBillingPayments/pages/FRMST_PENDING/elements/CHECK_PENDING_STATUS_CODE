<source type="Decision Editor"><![CDATA[<knowledge_base>
    <rule name="CHECK_PENDING_STATUS_CODE" default_exit_state="ER">
        <exit_state name="EXPIRE_PENDING" conjugate="and">
            <string operator="equal">
                <data>
                    <session name="S_HALO_API_ExpirePendingBillDue" />
                </data>
                <constant_string value="Y" />
            </string>
        </exit_state>
        <exit_state name="CANCEL_PENDING" conjugate="and">
            <string operator="equal">
                <data>
                    <session name="S_HALO_API_CancelPendingBillDue" />
                </data>
                <constant_string value="Y" />
            </string>
        </exit_state>
        <exit_state name="ER_PENDING" conjugate="and">
            <string operator="equal">
                <data>
                    <session name="PENDING_ERROR_FLAG" />
                </data>
                <constant_string value="Y" />
            </string>
        </exit_state>
    </rule>
</knowledge_base>]]></source>
